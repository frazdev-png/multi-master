# Frontend (Next.js) - Production
# NEXT_PUBLIC_API_URL: Internal PHP API URL for the Next.js proxy to use
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
# NEXT_PUBLIC_WS_URL: Public WebSocket URL (Nginx proxies /ws/ -> PHP WebSocket)
NEXT_PUBLIC_WS_URL=wss://sell1mall.com/ws
# API_URL: Alias, same as above
API_URL=http://127.0.0.1:8000
NEXT_PUBLIC_APP_URL=https://sell1mall.com
